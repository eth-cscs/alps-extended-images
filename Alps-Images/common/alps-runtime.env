# -----------------------------------------------------------------------------
# Helper: set default only if UNSET, then export
# -----------------------------------------------------------------------------
# Usage:
#   defvar VAR "default value"
#
# Semantics:
# - If VAR is unset: set it to the provided default.
# - If VAR is set (even if empty): do not touch it.
# - Always export VAR.
defvar() {
  local name="${1:?var name required}"; shift
  local default="$*"

  # If unset: set it. If set (even empty): keep it.
  if [[ ! ${!name+x} ]]; then
    printf -v "$name" '%s' "$default"
  fi
  export "$name"
}

# -----------------------------------------------------------------------------
# CUDA / general
# -----------------------------------------------------------------------------
# Disable CUDA cache for JIT compilation (common choice for shared filesystems,
# may avoid issues with cache corruption when multiple ranks share the same
# cache directory). This may lead to increased startup times for some
# applications. For more details, see the following NVIDIA blog post:
# https://developer.nvidia.com/blog/cuda-pro-tip-understand-fat-binaries-jit-caching/
defvar CUDA_CACHE_DISABLE "1"

# -----------------------------------------------------------------------------
# NCCL defaults
# -----------------------------------------------------------------------------
# NCCL_VERSION:
# Optional informational marker; will be injected at build time.
defvar NCCL_VERSION "${NCCL_VERSION:-}"

# This forces NCCL to use the libfabric plugin, enabling full use of the
# Slingshot network. If the plugin can not be found, applications will fail to
# start. With the default value, applications would instead fall back to e.g.
# TCP, which would be significantly slower than with the plugin. More
# information about `NCCL_NET` can be found at:
# https://docs.nvidia.com/deeplearning/nccl/user-guide/docs/env.html#nccl-net
defvar NCCL_NET "AWS Libfabric"

# Allow the use of different NICs for the same ring/tree. This is suited for
# networks where all NICs from a node are connected to the same switch, like
# Slingshot. More information about `NCCL_CROSS_NIC` can be found at:
# https://docs.nvidia.com/deeplearning/nccl/user-guide/docs/env.html#nccl-cross-nic
defvar NCCL_CROSS_NIC "1"

# Use P2P when GPUs are connected through NVLink.
# More information about `NCCL_P2P_LEVEL` can be found at:
# https://docs.nvidia.com/deeplearning/nccl/user-guide/docs/env.html#nccl-p2p-level
defvar NCCL_P2P_LEVEL "NVL"

# Use GPU Direct RDMA when GPU and NIC are on the same NUMA node. More
# information about `NCCL_NET_GDR_LEVEL` can be found at:
# https://docs.nvidia.com/deeplearning/nccl/user-guide/docs/env.html#nccl-net-gdr-level-formerly-nccl-ib-gdr-level
defvar NCCL_NET_GDR_LEVEL "PHB"
defvar NCCL_NET_GDR_C2C "1"
defvar NCCL_NET_GDR_READ "1"

# Starting with nccl 2.27 a new protocol (LL128) was enabled by default, which
# typically performs worse on Slingshot. The following disables that protocol.
defvar NCCL_PROTO "^LL128"

# Number of network channels to be used for pairwise communication.
# See https://docs.nvidia.com/deeplearning/nccl/user-guide/docs/api/types.html#c.nChannelsPerNetPeer
defvar NCCL_NCHANNELS_PER_NET_PEER "4"

# -----------------------------------------------------------------------------
# Libfabric / CXI defaults
# -----------------------------------------------------------------------------
# Select the libfabric provider.
defvar FI_PROVIDER "cxi"

# CXI sizing / performance knobs. These variables have been found to give the
# best performance on the Alps network across a wide range of applications.
# Specific applications may perform better with other values.
defvar FI_CXI_DEFAULT_CQ_SIZE "131072"
defvar FI_CXI_DEFAULT_TX_SIZE "16384"

# Disable registration of host buffers (overflow and request) with GPU.
# https://ofiwg.github.io/libfabric/v2.1.0/man/fi_cxi.7.html
defvar FI_CXI_DISABLE_HOST_REGISTER "1"

# Rendezvous settings:
# - Threshold/get-min at 0 enforces the configured rendezvous behavior consistently.
defvar FI_CXI_RDZV_PROTO "alt_read"
defvar FI_CXI_RDZV_EAGER_SIZE "0"
defvar FI_CXI_RDZV_GET_MIN "0"
defvar FI_CXI_RDZV_THRESHOLD "0"

# Cray MPI overrides the libfabric defaults with the following more efficient values.
# Set them explicitly here so that NCCL can benefit.
defvar FI_MR_CACHE_MAX_SIZE "-1"
defvar FI_MR_CACHE_MAX_COUNT "524288"

# Needed for AWS_OFI_NCCL_VERSION >= v1.14.2 to avoid "cxil_map: write error"
# due to enabling DMA-BUF by default.
# See https://github.com/aws/aws-ofi-nccl/releases/tag/v1.14.2
defvar OFI_NCCL_DISABLE_DMABUF 1

# Message matching begins fully offloaded, if resources become exhausted
# hardware will transition message matching to a hybrid of hardware and
# software matching, see
# https://ofiwg.github.io/libfabric/v2.1.0/man/fi_cxi.7.html.
defvar FI_CXI_RX_MATCH_MODE "hybrid"

# Memory registration cache monitoring method: userfaultfd is required when
# running applications with NCCL or RCCL.
defvar FI_MR_CACHE_MONITOR "userfaultfd"

# -----------------------------------------------------------------------------
# PMIx / OpenMPI defaults
# -----------------------------------------------------------------------------
# PMIX_MCA_psec: PMIx security framework. "Native" is needed to avoid
# warnings about missing security components when running with slurm on Alps.
defvar PMIX_MCA_psec "native"

# The Byte Transfer Layer (BTL) is a framework in Open MPI that is used for
# point-to-point communication between processes. By setting `OMPI_MCA_btl` to
# "^tcp,uct,usnic", we are telling Open MPI to exclude the TCP, UCT, and USNIC
# BTL components from being used for communication.
# More information about `OMPI_MCA_btl` can be found at:
# https://docs.open-mpi.org/en/v5.0.x/mca.html#frameworks
defvar OMPI_MCA_btl "^tcp,uct,usnic"
defvar OMPI_MCA_pml "cm"
defvar OMPI_MCA_mtl "ofi"
defvar OMPI_MCA_opal_common_ofi_provider_include "cxi"

# -----------------------------------------------------------------------------
# NVSHMEM defaults
# -----------------------------------------------------------------------------
# NVSHMEM_VERSION: Optional informational marker; will be injected at build
# time.
defvar NVSHMEM_VERSION "${NVSHMEM_VERSION:-}"

# Prefer libfabric for remote transport, using CXI.
defvar NVSHMEM_REMOTE_TRANSPORT "libfabric"
defvar NVSHMEM_LIBFABRIC_PROVIDER "cxi"

# The libfabric transport currently does not support VMM, so 23 must disable
# VMM, see https://github.com/NVIDIA/nvshmem/releases/tag/v3.5.19-1
defvar NVSHMEM_DISABLE_CUDA_VMM "1"
