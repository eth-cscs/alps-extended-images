+	/* Owned fid_mr objects, one per ctrl ep rail (FI_MR_ENDPOINT mode only).
+	 * In non-endpoint-MR mode this vector remains empty; mr_ctrl[] aliases mr_data[]. */
+	std::vector<ofi_mr_ptr> mr_ctrl_owned;
 
