 						 int type,
 						 nccl_net_ofi_rdma_ep_t *ep,
@@ -2563,13 +2586,16 @@ int nccl_net_ofi_rdma_domain_t::reg_mr_on_device(nccl_ofi_mr_ckey_ref ckey,
 
