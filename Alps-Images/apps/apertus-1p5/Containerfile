ARG BASE_IMAGE
FROM ${BASE_IMAGE}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ARG OCI_SOURCE="unknown"
ARG OCI_REVISION="unknown"
ARG OCI_CREATED="unknown"
ARG CSCS_ALPS_GIT_COMMIT_SHORT="unknown"

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      com.cscs.alps.git.repo="${OCI_SOURCE}" \
      com.cscs.alps.git.commit="${OCI_REVISION}" \
      com.cscs.alps.git.commit_short="${CSCS_ALPS_GIT_COMMIT_SHORT}"

RUN set -eux; \
    python -m pip install -i https://jfrog.svc.cscs.ch/artifactory/api/pypi/pypi-remote/simple \
        --no-cache-dir \
        --progress-bar off \
        flask-restful einops sentencepiece transformers tiktoken wandb nvidia-modelopt[hf]

ARG MEGATRON_REPO="https://github.com/swiss-ai/Megatron-LM.git"
ARG MEGATRON_COMMIT="multimodality/main"
ARG MEGATRON_PATCH_URL="https://patch-diff.githubusercontent.com/raw/NVIDIA/Megatron-LM/pull/1871.patch"

RUN set -eux; \
    git clone "${MEGATRON_REPO}" /opt/megatron; \
    cd /opt/megatron; \
    git checkout -q "${MEGATRON_COMMIT}"; \
    curl -fsSL "${MEGATRON_PATCH_URL}" -o /tmp/megatron-1871.patch; \
    if git apply --3way --check /tmp/megatron-1871.patch; then \
        git apply --3way /tmp/megatron-1871.patch; \
    elif git apply --reverse --check /tmp/megatron-1871.patch; then \
        echo "Patch already applied, skipping."; \
    else \
        echo "Patch does not apply cleanly."; \
        exit 1; \
    fi; \
    rm -f /tmp/megatron-1871.patch; \
    python3 setup.py build_ext --inplace;

# Tests shipped with the image
COPY Alps-Images/apps/apertus-1p5/tests/ /opt/tests/apertus-1p5/
RUN chmod -R a+rX /opt/tests/apertus-1p5

WORKDIR /opt/megatron
