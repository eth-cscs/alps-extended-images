ARG BASE_IMAGE
FROM ${BASE_IMAGE}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ARG OCI_SOURCE="unknown"
ARG OCI_REVISION="unknown"
ARG OCI_CREATED="unknown"
ARG CSCS_ALPS_GIT_COMMIT_SHORT="unknown"

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      com.cscs.alps.git.repo="${OCI_SOURCE}" \
      com.cscs.alps.git.commit="${OCI_REVISION}" \
      com.cscs.alps.git.commit_short="${CSCS_ALPS_GIT_COMMIT_SHORT}"

RUN set -eux; \
    python -m pip install -i https://jfrog.svc.cscs.ch/artifactory/api/pypi/pypi-remote/simple \
        --no-cache-dir \
        --progress-bar off \
        transformers

# System deps
RUN set -eux; \
    apt-get update; \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      ca-certificates \
      curl \
      git \
      pkg-config \
      clang \
      libclang-dev \
      python3-dev \
      python3-venv \
    ; \
    rm -rf /var/lib/apt/lists/*

# Manually link libibverbs.so
RUN set -eux; \
    arch="$(dpkg-architecture -qDEB_HOST_MULTIARCH)"; \
    libdir="/usr/lib/${arch}"; \
    if [[ ! -e "${libdir}/libibverbs.so" && -e "${libdir}/libibverbs.so.1" ]]; then \
        ln -sf "${libdir}/libibverbs.so.1" "${libdir}/libibverbs.so"; \
        ldconfig; \
    fi

# Rust toolchain (via rustup) installed under /opt
ENV RUSTUP_HOME=/opt/rust/rustup \
    CARGO_HOME=/opt/rust/cargo \
    PATH=/opt/rust/cargo/bin:$PATH \
    RUSTUP_DISABLE_SELF_UPDATE=1

RUN set -eux; \
    mkdir -p "${RUSTUP_HOME}" "${CARGO_HOME}"; \
    curl --proto '=https' --tlsv1.2 -fsSL https://sh.rustup.rs | sh -s -- -y \
      --no-modify-path \
      --default-toolchain 1.91.0 \
      --component llvm-tools-preview; \
    rustc --version; \
    cargo --version; \
    rustup component list --installed

# Install patched pplx-garden
ARG PPLX_GARDEN_REPO=https://github.com/pinxuezhao/pplx_garden_cxi.git
ARG PPLX_GARDEN_COMMIT=3ce62f9993b6e4abdcda8dac3b87a944ea221f4f
RUN set -eux; \
    python3 -m pip show build >/dev/null 2>&1 || python3 -m pip install -i https://jfrog.svc.cscs.ch/artifactory/api/pypi/pypi-remote/simple --no-cache-dir build; \
    rm -rf /tmp/pplx_garden; \
    git clone --depth 1 "${PPLX_GARDEN_REPO}" /tmp/pplx_garden; \
    pushd /tmp/pplx_garden; \
    git fetch --depth 1 origin "${PPLX_GARDEN_COMMIT}"; \
    git checkout -q "${PPLX_GARDEN_COMMIT}"; \
    export TORCH_CMAKE_PREFIX_PATH="$(python3 -c 'import torch; print(torch.utils.cmake_prefix_path)')"; \
    python3 -m build --wheel; \
    python3 -m pip install -i https://jfrog.svc.cscs.ch/artifactory/api/pypi/pypi-remote/simple --no-cache-dir dist/*.whl; \
    popd; \
    # Vendor benchmark code into the image
    rm -rf /opt/pplx-garden; \
    mkdir /opt/pplx-garden; \
    cp -a /tmp/pplx_garden/benchmarks /opt/pplx-garden/benchmarks; \
    cp -a /tmp/pplx_garden/tests /opt/pplx-garden/tests; \
    rm -rf /tmp/pplx_garden

# Install DeepEP
ARG DEEPEP_REPO=https://github.com/boeschf/DeepEP.git
ARG DEEPEP_COMMIT=ea669122295c9a8f47ed13f69e408fb745dc7bca
RUN set -eux; \
    git clone --depth 1 "${DEEPEP_REPO}" /tmp/DeepEP; \
    pushd /tmp/DeepEP; \
    git fetch --depth 1 origin "${DEEPEP_COMMIT}"; \
    git checkout -q "${DEEPEP_COMMIT}"; \
    NVSHMEM_DIR=/opt/nvshmem \
    DISABLE_SM90_FEATURES=0 \
    TORCH_CUDA_ARCH_LIST="9.0" \
    DISABLE_AGGRESSIVE_PTX_INSTRS=0 \
        python setup.py install; \
    popd; \
    # Vendor benchmark code into the image
    rm -rf /opt/DeepEP; \
    mkdir /opt/DeepEP; \
    cp -a /tmp/DeepEP/tests /opt/DeepEP/tests; \
    rm -rf /tmp/DeepEP

# Install quack-kernels
ARG QUACK_REPO=https://github.com/Dao-AILab/quack.git
ARG QUACK_TAG=v0.2.10
RUN set -eux; \
    git clone --depth 1 --branch "${QUACK_TAG}" "${QUACK_REPO}" /tmp/quack; \
    pushd /tmp/quack; \
    python -m pip install -i https://jfrog.svc.cscs.ch/artifactory/api/pypi/pypi-remote/simple --upgrade-strategy only-if-needed '.[cu13]'; \
    popd; \
    rm -rf /tmp/quack

# Tests shipped with the image
COPY Alps-Images/apps/apertus-2/tests/ /opt/tests/apertus-2/
RUN chmod -R a+rX /opt/tests/apertus-2

## Install cuBLASMp
#RUN set -eux; \
#    wget https://developer.download.nvidia.com/compute/cublasmp/0.8.0/local_installers/cublasmp-local-repo-ubuntu2404-0.8.0_0.8.0-1_arm64.deb; \
#    dpkg -i cublasmp-local-repo-ubuntu2404-0.8.0_0.8.0-1_arm64.deb; \
#    cp /var/cublasmp-local-repo-ubuntu2404-0.8.0/cublasmp-*-keyring.gpg /usr/share/keyrings/; \
#    apt-get update; \
#    apt-get -y install cublasmp; \
#    apt-get -y install cublasmp-cuda-13; \
#    rm -f cublasmp-local-repo-ubuntu2404-0.8.0_0.8.0-1_arm64.deb
ARG CUBLASMP_URL=https://developer.download.nvidia.com/compute/cublasmp/redist/libcublasmp/linux-sbsa/libcublasmp-linux-sbsa-0.7.0.125_cuda13-archive.tar.xz

RUN set -eux; \
    mkdir -p /opt/cublasmp /tmp/cublasmp-extract; \
    curl -fsSL "${CUBLASMP_URL}" -o /tmp/libcublasmp.tar.xz; \
    tar -xf /tmp/libcublasmp.tar.xz -C /tmp/cublasmp-extract; \
    cublasmp_root="$(find /tmp/cublasmp-extract -mindepth 1 -maxdepth 1 -type d | head -n 1)"; \
    test -n "${cublasmp_root}"; \
    cp -a "${cublasmp_root}/include" /opt/cublasmp/; \
    cp -a "${cublasmp_root}/lib" /opt/cublasmp/; \
    test -e /opt/cublasmp/lib/libcublasmp.so || \
      ln -sf "$(find /opt/cublasmp/lib -maxdepth 1 -name 'libcublasmp.so.*' | head -n 1)" /opt/cublasmp/lib/libcublasmp.so; \
    echo /opt/cublasmp/lib > /etc/ld.so.conf.d/cublasmp.conf; \
    ldconfig; \
    test -f /opt/cublasmp/lib/libcublasmp.so; \
    rm -rf /tmp/cublasmp-extract /tmp/libcublasmp.tar.xz

# Install Transformer Engine
ARG TE_VERSION=v2.12
ARG NVSHMEM_HOME=/opt/nvshmem
ARG CUBLASMP_HOME=/opt/cublasmp
RUN set -eux; \
    python -m pip install --upgrade pip; \
    python -m pip install --no-cache-dir \
        'setuptools>=61' \
        wheel \
        'cmake>=3.21' \
        ninja \
        'pybind11[global]' \
        packaging \
        pydantic \
        importlib-metadata; \
    git clone --branch "${TE_VERSION}" --recursive https://github.com/NVIDIA/TransformerEngine.git /tmp/TransformerEngine; \
    cd /tmp/TransformerEngine; \
    grep -q 'cuda_driver.h' transformer_engine/common/nvshmem_api/nvshmem_waitkernel.cu || \
      sed -i '/#include "..\/util\/logging.h"/a #include "..\/util\/cuda_driver.h"' \
        transformer_engine/common/nvshmem_api/nvshmem_waitkernel.cu; \
    grep -qxF 'target_include_directories(nvshmemapi PRIVATE "${CMAKE_CURRENT_SOURCE_DIR}/../include")' \
      transformer_engine/common/nvshmem_api/CMakeLists.txt || \
      printf '\n%s\n' \
        'target_include_directories(nvshmemapi PRIVATE "${CMAKE_CURRENT_SOURCE_DIR}/../include")' \
        >> transformer_engine/common/nvshmem_api/CMakeLists.txt; \
    export NVTE_FRAMEWORK=pytorch; \
    export NVTE_CUDA_ARCHS="90"; \
    export NVTE_ENABLE_NVSHMEM=1; \
    export NVSHMEM_HOME="${NVSHMEM_HOME}"; \
    export NVTE_WITH_CUBLASMP=1; \
    export CUBLASMP_HOME="${CUBLASMP_HOME}"; \
    export MAX_JOBS="$(nproc)"; \
    export NVTE_BUILD_THREADS_PER_JOB=4; \
    export CPATH="/usr/local/cuda/include/cccl:/usr/local/cuda/targets/sbsa-linux/include/cccl:${CPATH:-}"; \
    export CPLUS_INCLUDE_PATH="/usr/local/cuda/include/cccl:/usr/local/cuda/targets/sbsa-linux/include/cccl:${CPLUS_INCLUDE_PATH:-}"; \
    python -m pip install -v --no-build-isolation .; \
    rm -rf /tmp/TransformerEngine

# Add FA3 Hopper as a separate install (for Megatron)
ARG FLASH_ATTN3_REF=main
ARG FA3_JOBS=20
RUN set -eux; \
    python -m pip install --upgrade pip setuptools wheel; \
    python -m pip install --no-cache-dir packaging ninja einops; \
    git clone --recursive https://github.com/Dao-AILab/flash-attention.git /tmp/flash-attention; \
    cd /tmp/flash-attention; \
    git checkout "${FLASH_ATTN3_REF}"; \
    git submodule update --init --recursive; \
    cd hopper; \
    export FLASH_ATTENTION_FORCE_BUILD=TRUE; \
    export FLASH_ATTENTION_DISABLE_SM80=TRUE; \
    export MAX_JOBS="${FA3_JOBS}"; \
    export CMAKE_BUILD_PARALLEL_LEVEL="${FA3_JOBS}"; \
    export NINJA_NUM_JOBS="${FA3_JOBS}"; \
    export FLASH_ATTENTION_FORCE_CXX11_ABI=TRUE; \
    python setup.py build_ext --verbose --parallel "${FA3_JOBS}" bdist_wheel; \
    python -m pip install --no-cache-dir dist/*.whl; \
    python_site="$(python -c 'import site; print(site.getsitepackages()[0])')"; \
    python -c 'import flash_attn_interface; print("top-level FA3 import OK")'; \
    mkdir -p "${python_site}/flash_attn_3"; \
    printf '%s\n' 'from .flash_attn_interface import *' > "${python_site}/flash_attn_3/__init__.py"; \
    printf '%s\n' 'from flash_attn_interface import *' > "${python_site}/flash_attn_3/flash_attn_interface.py"; \
    python -c 'import flash_attn_3.flash_attn_interface as m; print("flash-attn v3 import OK:", hasattr(m, "flash_attn_func"))'; \
    rm -rf /tmp/flash-attention
