# syntax=docker/dockerfile:1

# Special thanks to Eduard Durech for his work on the original VeRL image for Alps.

ARG BASE_IMAGE
FROM ${BASE_IMAGE}

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ARG OCI_SOURCE="unknown"
ARG OCI_REVISION="unknown"
ARG OCI_CREATED="unknown"
ARG OCI_DESCRIPTION="unknown"
ARG CSCS_ALPS_GIT_COMMIT_SHORT="unknown"

LABEL org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.revision="${OCI_REVISION}" \
      org.opencontainers.image.created="${OCI_CREATED}" \
      org.opencontainers.image.description="${OCI_DESCRIPTION}" \
      com.cscs.alps.git.repo="${OCI_SOURCE}" \
      com.cscs.alps.git.commit="${OCI_REVISION}" \
      com.cscs.alps.git.commit_short="${CSCS_ALPS_GIT_COMMIT_SHORT}"

# Install dependencies for VeRL from pypi, including vLLM and SGLang.

#Note: disable vllm installation for now, as it causes issues. To re-enable consider using the ngc vllm base image.
#RUN pip install vllm --extra-index-url https://download.pytorch.org/whl/cu131

RUN pip install sglang[all]
RUN pip install flash-attn --no-build-isolation


# Install dependencies for VeRL from source, including flashinfer, flash-attention, torch_memory_saver, XIELU

ENV SRC_DIR=/workspace/src \
    WHL_DIR=/workspace/src/wheels

WORKDIR ${SRC_DIR}


#RUN git clone https://github.com/nickjbrowning/XIELU.git ;\
#    cd XIELU ;\
#    git submodule update --init --recursive ;\
#    python -m build --wheel --no-isolation --outdir=${WHL_DIR} 2>&1 | tee ./build.log
#RUN pip install --no-deps --no-cache-dir --force-reinstall ${WHL_DIR}/xielu*.whl


WORKDIR /workspace

RUN rm -rf ${SRC_DIR}

RUN git clone https://github.com/verl-project/verl
RUN cd verl && pip install --no-deps -e ".[sglang]"

RUN pip install -U "ray[data,train,tune,serve]"
RUN pip install "tensordict==0.10.0" omegaconf hydra-core codetiming peft pylatexenc wandb TransferQueue==0.1.6
RUN pip uninstall kernels -y --break-system-packages 